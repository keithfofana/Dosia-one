# Copier ce fichier en `keystore.properties` (meme dossier), a cote de ce .example,
# puis renseigner les vraies valeurs. Ce fichier n'est JAMAIS committe (voir .gitignore).
# Voir le README (racine du projet) pour la commande `keytool` qui genere le .keystore.
storeFile=dosia-one-release.keystore
storePassword=CHANGE_ME
keyAlias=dosia-one
keyPassword=CHANGE_ME
