APP_NAME="Dosia One"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Base de données (PostgreSQL / AWS RDS) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=dosia_one
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Stockage de fichiers ---
# En développement : stockage local (storage/app/private), aucune clé AWS requise.
# Pour passer en production sur S3 : renseigner les clés AWS ci-dessous puis
# régler FILESYSTEM_DISK=s3 (voir README.md, section "Stockage de fichiers").
FILESYSTEM_DISK=local

# --- AWS (utilisé uniquement si FILESYSTEM_DISK=s3, ou pour SES/SNS ci-dessous) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=dosia-one-storage
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Auth / Sécurité ---
SANCTUM_STATEFUL_DOMAINS=localhost
TWO_FACTOR_ENABLED=true

# --- Notifications (SNS / SES pour email + SMS) ---
AWS_SNS_TOPIC=
MAIL_MAILER=ses
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- WhatsApp Business API ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Assistant IA (Anthropic) ---
ANTHROPIC_API_KEY=

VITE_APP_NAME="${APP_NAME}"
